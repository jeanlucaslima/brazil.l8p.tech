        </div>
      </div>
    </section>

    <!-- ═══ Ecosystem ═══ -->
    <section id="ecosystem" class="reveal-section relative py-36">
      <div class="contour-divider"></div>

      <div class="mx-auto max-w-7xl px-6">
        <div class="mx-auto max-w-2xl text-center">
