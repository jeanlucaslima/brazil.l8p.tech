  </div>

  <style>
    /* ── Page theme ── */
    .page {
      background-color: #F0F2F8;
    }

    /* ── Hero section: exactly one viewport, content at bottom ── */
    .hero-section {
      height: 100svh;
      height: 100dvh; /* fallback chain */
      overflow-y: clip;
    }

    /* ── Vertical text ── */
    .writing-vertical {
      writing-mode: vertical-rl;
      text-orientation: mixed;
    }

    /* ── HUD menu button ── */
    .hud-btn {
      font-family: var(--font-mono);
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--color-accent);
      border: 1px solid var(--color-accent);
      padding: 6px 14px;
      position: relative;
      transition: background 0.2s ease, color 0.2s ease;
    }

    .hud-btn:hover,
    .hud-btn.is-open {
      background: var(--color-accent);
      color: #fff;
    }

    /* Corner notches — like LCARS / cockpit interface */
    .hud-btn::before,
    .hud-btn::after {
      content: '';
      position: absolute;
      width: 5px;
      height: 5px;
      border-color: var(--color-accent);
    }

    .hud-btn::before {
      top: -3px;
      left: -3px;
      border-top: 1.5px solid;
      border-left: 1.5px solid;
    }

    .hud-btn::after {
      bottom: -3px;
      right: -3px;
      border-bottom: 1.5px solid;
      border-right: 1.5px solid;
    }

    .hud-btn.is-open::before,
    .hud-btn.is-open::after {
      border-color: #fff;
    }

    /* ── HUD edge readouts ── */
    .hud-readout {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 2px;
    }

    .hud-readout-label {
      font-family: var(--font-mono);
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: rgba(59,108,181,0.25);
    }

    .hud-readout-value {
      font-family: var(--font-mono);
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.05em;
      color: rgba(59,108,181,0.18);
    }

    /* ── HUD cockpit card with targeting brackets ── */
    .cockpit-card {
      background: #FFFFFF;
      border: 1px solid var(--color-edge);
      box-shadow: 0 1px 3px rgba(12,26,58,0.04);
      position: relative;
    }

    /* Targeting brackets — corner marks */
    .cockpit-card::before,
    .cockpit-card::after {
      content: '';
      position: absolute;
      width: 12px;
      height: 12px;
      border-color: var(--color-accent);
      opacity: 0.25;
      transition: opacity 0.3s ease;
    }

    .cockpit-card::before {
      top: -1px;
      left: -1px;
      border-top: 1.5px solid;
      border-left: 1.5px solid;
    }

    .cockpit-card::after {
      bottom: -1px;
      right: -1px;
      border-bottom: 1.5px solid;
      border-right: 1.5px solid;
    }

    .cockpit-card:hover::before,
    .cockpit-card:hover::after {
      opacity: 0.5;
    }

    /* ── Contour divider ── */
    .contour-divider {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: repeating-linear-gradient(
        90deg,
        rgba(59,108,181,0.1) 0,
        rgba(59,108,181,0.1) 6px,
        transparent 6px,
        transparent 16px
      );
      mask-image: linear-gradient(90deg, transparent 0%, rgba(0,0,0,1) 15%, rgba(0,0,0,1) 85%, transparent 100%);
      -webkit-mask-image: linear-gradient(90deg, transparent 0%, rgba(0,0,0,1) 15%, rgba(0,0,0,1) 85%, transparent 100%);
    }

    /* ── Contour line animation layers ── */
    .contour-layer {
      animation: contour-drift 40s linear infinite;
    }

    .contour-layer-slow {
      animation: contour-drift 60s linear infinite reverse;
    }

    /* ── HUD menu links ── */
    .hud-menu-link:hover {
      background: var(--color-accent) !important;
      color: #fff !important;
      border-color: var(--color-accent) !important;
    }

    /* ── CTA pulse ── */
    .cta-button {
      position: relative;
    }

    .cta-button::before {
      content: '';
      position: absolute;
      inset: -1px;
      border-radius: inherit;
      border: 1px solid var(--color-accent);
      animation: blip-pulse 3s ease-in-out infinite;
    }

    /* ── ConfrariaTech logo ── */
    .confraria-logo {
      filter: brightness(0.25);
    }

    /* ── Mobile menu ── */
    .mobile-menu {
      max-height: 0;
      overflow: hidden;
      opacity: 0;
      background: rgba(240,242,248,0.97);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(59,108,181,0.08);
      transition: max-height 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                  opacity 0.3s ease;
    }

    .mobile-menu.is-open {
      max-height: 320px;
      opacity: 1;
    }

    .mobile-menu-link:hover {
      color: var(--color-accent) !important;
    }

    /* ── Scroll reveal ── */
    .reveal-section {
      opacity: 0;
      transform: translateY(32px);
      transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .reveal-section.is-visible {
      opacity: 1;
      transform: translateY(0);
    }
  </style>

  <script>
    // Mobile menu toggle
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');

    menuBtn?.addEventListener('click', () => {
      const isOpen = mobileMenu?.classList.toggle('is-open');
      menuBtn.classList.toggle('is-open', isOpen);
      menuBtn.setAttribute('aria-expanded', String(isOpen));
      mobileMenu?.setAttribute('aria-hidden', String(!isOpen));
    });

    mobileMenu?.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        mobileMenu.classList.remove('is-open');
        menuBtn?.classList.remove('is-open');
        menuBtn?.setAttribute('aria-expanded', 'false');
        mobileMenu.setAttribute('aria-hidden', 'true');
      });
    });

    // Scroll-triggered section reveals
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
          }
        });
      },
      { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
    );

    document.querySelectorAll('.reveal-section').forEach((el) => {
      observer.observe(el);
    });
  </script>
</Layout>
