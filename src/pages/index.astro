---
import Layout from "../layouts/Layout.astro";

const team = [
  {
    name: "Eduardo Kupper",
    initials: "EK",
    image: "/team/kupper.jpeg",
    company: "Airborne Ventures",
    linkedin: "https://www.linkedin.com/in/eduardokupper/",
  },
  {
    name: "Jean Lucas Lima",
    initials: "JL",
    image: "/team/jeanlucas.jpeg",
    company: "ConfrariaTech",
    linkedin: "https://www.linkedin.com/in/jeanlucaslima",
  },
];

const ecosystem = [
  { name: "Airborne Ventures", logo: "/logos/airborne-full.svg", noFilter: true },
  { name: "ConfrariaTech", logo: "/logos/confrariatech.svg" },
];

const year = new Date().getFullYear();
---

<Layout title="Airborne Day · CEOs & Entrepreneurs in New York City">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Event",
    "name": "Airborne Day",
    "description": "An invite-only full-day gathering of CEOs and entrepreneurs in New York City. Small rooms, real conversations, leaders only.",
    "location": {
      "@type": "Place",
      "name": "Tailor Partners",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "345 Avenue of the Americas, 2nd floor, Room 2.078",
        "addressLocality": "New York",
        "addressRegion": "NY",
        "addressCountry": "US"
      }
    },
    "startDate": "2026-05-14T09:00:00-04:00",
    "endDate": "2026-05-14T18:00:00-04:00",
    "organizer": [
      { "@type": "Organization", "name": "Airborne Ventures", "url": "https://www.airborne.ventures/" },
      { "@type": "Organization", "name": "ConfrariaTech" }
    ]
  })} />

  <div class="page relative overflow-x-hidden">

    <!-- ═══ Background: Atmosphere ═══ -->
    <div class="pointer-events-none fixed inset-0 overflow-hidden">
      <!-- Horizon gradient band -->
      <div class="absolute top-0 left-0 right-0 h-[50vh] animate-shimmer"
        style="background: linear-gradient(180deg, rgba(59,108,181,0.05) 0%, rgba(123,164,212,0.02) 40%, transparent 100%);">
      </div>

      <!-- Topographic altitude contour lines -->
      <svg class="absolute inset-0 h-full w-full contour-layer" preserveAspectRatio="none" viewBox="0 0 1600 900">
        <!-- Major contour lines -->
        <path d="M-50,120 Q150,80 350,130 Q550,180 750,110 Q950,40 1150,100 Q1350,160 1550,90 L1700,95" fill="none" stroke="rgba(59,108,181,0.07)" stroke-width="1.2" />
        <path d="M-50,380 Q200,340 400,400 Q600,460 800,370 Q1000,280 1200,360 Q1400,440 1650,350" fill="none" stroke="rgba(59,108,181,0.06)" stroke-width="1.2" />
        <path d="M-50,650 Q180,610 380,670 Q580,730 780,640 Q980,550 1180,630 Q1380,710 1650,620" fill="none" stroke="rgba(59,108,181,0.05)" stroke-width="1.2" />

        <!-- Minor contour lines -->
        <path d="M-50,170 Q180,140 380,180 Q580,220 780,155 Q980,90 1180,145 Q1380,200 1650,140" fill="none" stroke="rgba(59,108,181,0.04)" stroke-width="0.6" />
        <path d="M-50,230 Q200,205 400,240 Q600,275 800,210 Q1000,145 1200,200 Q1400,255 1650,195" fill="none" stroke="rgba(59,108,181,0.035)" stroke-width="0.6" />
        <path d="M-50,430 Q190,400 390,445 Q590,490 790,415 Q990,340 1190,405 Q1390,470 1650,400" fill="none" stroke="rgba(59,108,181,0.035)" stroke-width="0.6" />
        <path d="M-50,550 Q170,520 370,560 Q570,600 770,530 Q970,460 1170,525 Q1370,590 1650,520" fill="none" stroke="rgba(59,108,181,0.03)" stroke-width="0.6" />
        <path d="M-50,700 Q200,675 400,715 Q600,755 800,685 Q1000,615 1200,680 Q1400,745 1650,670" fill="none" stroke="rgba(59,108,181,0.035)" stroke-width="0.6" />
        <path d="M-50,830 Q220,800 420,845 Q620,890 820,810 Q1020,730 1220,800 Q1420,870 1650,795" fill="none" stroke="rgba(59,108,181,0.025)" stroke-width="0.6" />

        <!-- Altitude labels -->
        <text x="1420" y="117" fill="rgba(59,108,181,0.08)" font-family="Space Mono, monospace" font-size="8" letter-spacing="0.05em">35000</text>
        <text x="1480" y="377" fill="rgba(59,108,181,0.07)" font-family="Space Mono, monospace" font-size="8" letter-spacing="0.05em">28000</text>
        <text x="1440" y="647" fill="rgba(59,108,181,0.06)" font-family="Space Mono, monospace" font-size="8" letter-spacing="0.05em">21000</text>
      </svg>

      <!-- Second contour layer (depth) -->
      <svg class="absolute inset-0 h-full w-full contour-layer-slow" preserveAspectRatio="none" viewBox="0 0 1600 900" style="opacity: 0.5;">
        <path d="M-50,80 Q250,50 450,95 Q650,140 850,70 Q1050,0 1250,65 Q1450,130 1700,60" fill="none" stroke="rgba(59,108,181,0.05)" stroke-width="0.8" stroke-dasharray="4,8" />
        <path d="M-50,320 Q220,285 420,335 Q620,385 820,310 Q1020,235 1220,305 Q1420,375 1700,300" fill="none" stroke="rgba(59,108,181,0.04)" stroke-width="0.8" stroke-dasharray="4,8" />
        <path d="M-50,580 Q240,545 440,595 Q640,645 840,570 Q1040,495 1240,565 Q1440,635 1700,560" fill="none" stroke="rgba(59,108,181,0.03)" stroke-width="0.8" stroke-dasharray="4,8" />
      </svg>

      <!-- Radar rings -->
      <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2">
        <div class="absolute h-[500px] w-[500px] -translate-x-1/2 -translate-y-1/2 rounded-full border border-dashed animate-radar" style="border-color: rgba(59,108,181,0.06);"></div>
        <div class="absolute h-[500px] w-[500px] -translate-x-1/2 -translate-y-1/2 rounded-full border border-dashed animate-radar" style="border-color: rgba(59,108,181,0.04); animation-delay: 1.3s;"></div>
        <div class="absolute h-[500px] w-[500px] -translate-x-1/2 -translate-y-1/2 rounded-full border border-dashed animate-radar" style="border-color: rgba(59,108,181,0.03); animation-delay: 2.6s;"></div>
      </div>

      <!-- Ambient glow -->
      <div class="absolute left-1/4 top-1/3 h-[600px] w-[600px] rounded-full blur-[150px] animate-breathe" style="background: rgba(59,108,181,0.04);"></div>
    </div>

    <!-- ═══ Header ═══ -->
    <header class="fixed top-0 left-0 right-0 z-50 backdrop-blur-xl" style="border-bottom: 1px solid rgba(59,108,181,0.08); background: rgba(240,242,248,0.9);">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-5">
        <a href="/" class="group">
          <img src="/logos/airborne-full.svg" alt="Airborne" class="h-8 w-auto" />
        </a>

        <!-- HUD menu button -->
        <button id="mobile-menu-btn" class="hud-btn group" aria-label="Menu" aria-expanded="false">
          <span class="hud-btn-text">MENU</span>
        </button>
      </div>

      <!-- Mobile menu panel -->
      <div id="mobile-menu" class="mobile-menu" aria-hidden="true">
        <nav class="flex flex-col items-center gap-4 px-6 py-10 md:flex-row md:justify-center md:gap-3 md:py-6">
          <a href="#about" class="hud-menu-link font-mono text-[10px] font-700 uppercase tracking-[0.2em] px-6 py-2 transition-colors" style="color: var(--color-accent); border: 1px solid rgba(59,108,181,0.2);">About</a>
          <a href="#team" class="hud-menu-link font-mono text-[10px] font-700 uppercase tracking-[0.2em] px-6 py-2 transition-colors" style="color: var(--color-accent); border: 1px solid rgba(59,108,181,0.2);">Team</a>
          <a href="#ecosystem" class="hud-menu-link font-mono text-[10px] font-700 uppercase tracking-[0.2em] px-6 py-2 transition-colors" style="color: var(--color-accent); border: 1px solid rgba(59,108,181,0.2);">Ecosystem</a>
          <div class="mt-2 h-px w-16 md:hidden" style="background: rgba(59,108,181,0.1);"></div>
          <span
            class="font-mono text-[10px] font-700 uppercase tracking-[0.2em] px-6 py-2 cursor-default opacity-40"
            style="color: var(--color-accent); border: 1px solid rgba(59,108,181,0.15);"
          >
            Request Invite
          </span>
        </nav>
      </div>
    </header>

    <!-- ═══ Hero ═══ -->
    <section class="hero-section relative flex flex-col pt-20">
      <div class="flex-1 min-h-[60px]"></div>
      <div class="relative mx-auto max-w-7xl px-6 pb-12 md:pb-24 w-full flex-shrink-0">
        <div class="max-w-5xl">
          <!-- Massive title -->
          <div class="overflow-y-hidden">
            <h1 class="animate-hero-reveal font-display leading-[0.85] tracking-tighter" style="animation-delay: 0.2s;">
              <span class="block text-[clamp(3.5rem,12vw,14rem)] font-800" style="color: var(--color-midnight);">AIRBORNE</span>
              <span class="block text-[clamp(2rem,6vw,7rem)] font-400 mt-1 md:mt-2" style="color: var(--color-accent);">Day</span>
            </h1>
          </div>

          <!-- Subtitle -->
          <p
            class="animate-fade-up mt-6 md:mt-10 max-w-lg text-lg md:text-xl leading-relaxed"
            style="animation-delay: 0.5s; color: var(--color-muted);"
          >
            An invite-only full-day gathering of CEOs and entrepreneurs in New York City.
          </p>

          <!-- Cockpit readout: Date block -->
          <div class="animate-fade-up mt-6 md:mt-10 inline-flex flex-col items-start cockpit-card rounded-lg px-6 py-4 md:px-8 md:py-6" style="animation-delay: 0.6s;">
            <span class="font-mono text-[10px] font-700 tracking-[0.2em] uppercase" style="color: var(--color-accent);">Event Date</span>
            <span class="font-mono text-3xl font-700 mt-2 sm:text-4xl" style="color: var(--color-midnight);">MAY 14, 2026</span>
            <div class="flex items-center gap-3 mt-3">
              <span class="font-mono text-xs uppercase tracking-wider" style="color: var(--color-subtle);">Full Day</span>
              <span class="h-1 w-1 rounded-full" style="background: var(--color-accent);"></span>
              <span class="font-mono text-xs uppercase tracking-wider" style="color: var(--color-subtle);">New York City</span>
            </div>
            <span class="mt-3 font-mono text-[10px]" style="color: var(--color-subtle);"><a href="https://maps.google.com/?q=345+Avenue+of+the+Americas,+New+York,+NY" target="_blank" rel="noopener noreferrer" class="underline underline-offset-2 transition-opacity hover:opacity-70">Tailor Partners · 345 Avenue of the Americas</a></span>
          </div>

          <p class="animate-fade-up mt-4 md:mt-8 text-xs font-mono" style="animation-delay: 0.7s; color: var(--color-subtle);">
            Organized by
            <a href="https://www.airborne.ventures/" target="_blank" rel="noopener noreferrer" class="font-700 transition-opacity hover:opacity-70" style="color: var(--color-accent);">Airborne Ventures</a>
            &
            <span class="font-700" style="color: var(--color-muted);">ConfrariaTech</span>
          </p>
        </div>

        <!-- HUD edge readouts -->
        <div class="hidden lg:block">
          <!-- Right side: altitude readouts -->
          <div class="animate-fade-up absolute top-40 right-8 flex flex-col items-end gap-8" style="animation-delay: 0.9s;">
            <div class="hud-readout">
              <span class="hud-readout-label">ALT</span>
              <span class="hud-readout-value">FL350</span>
            </div>
            <div class="hud-readout">
              <span class="hud-readout-label">HDG</span>
              <span class="hud-readout-value">074°</span>
            </div>
            <div class="hud-readout">
              <span class="hud-readout-label">SPD</span>
              <span class="hud-readout-value">M0.84</span>
            </div>
          </div>

          <!-- Bottom right: coordinates -->
          <div class="animate-fade-up absolute bottom-32 right-8" style="animation-delay: 1s;">
            <span class="font-mono text-[10px] tracking-wider" style="color: rgba(59,108,181,0.18);">40.7234°N 74.0052°W</span>
          </div>
        </div>
      </div>

      <!-- Dashed flight-path divider -->
      <div class="absolute bottom-0 left-0 right-0 h-px" style="background: repeating-linear-gradient(90deg, rgba(59,108,181,0.12) 0, rgba(59,108,181,0.12) 8px, transparent 8px, transparent 20px);"></div>
    </section>

    <!-- ═══ Brazil Week Banner ═══ -->
    <section class="relative overflow-hidden py-16" style="background: linear-gradient(135deg, #0a1a12 0%, #0d2818 40%, #0a1a0e 100%);">
      <div class="pointer-events-none absolute -left-20 top-1/2 h-[300px] w-[300px] -translate-y-1/2 rounded-full blur-[100px]" style="background: rgba(0, 156, 59, 0.1);"></div>
      <div class="pointer-events-none absolute -right-10 -top-10 h-[250px] w-[250px] rounded-full blur-[90px]" style="background: rgba(255, 200, 0, 0.06);"></div>

      <div class="relative mx-auto max-w-5xl px-6">
        <div class="flex flex-col items-center gap-6 text-center lg:flex-row lg:text-left lg:gap-12">
          <div class="flex-1">
            <span class="font-mono text-xs font-700 tracking-[0.2em] uppercase" style="color: rgba(0, 200, 80, 0.5);">Part of</span>
            <h2 class="mt-2 font-display text-2xl font-800 tracking-tight sm:text-3xl" style="background: linear-gradient(135deg, #ffffff, #a8e6a0); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
              Brazil Week NYC
            </h2>
            <div class="mx-auto mt-3 h-px w-16 lg:mx-0" style="background: linear-gradient(to right, rgba(0, 156, 59, 0.4), rgba(255, 200, 0, 0.3), transparent);"></div>
            <p class="mt-4 text-base leading-relaxed" style="color: rgba(255,255,255,0.55);">
              A series of high-level events in New York City promoting Brazilian business, innovation, and technology. Brazil Week brings together government officials, investors, and entrepreneurs to discuss economic opportunities and showcase Brazilian innovation across sectors like technology, sustainability, and the creative economy.
            </p>
          </div>
          <div class="shrink-0">
            <div class="inline-flex flex-col items-center rounded-lg px-6 py-4" style="background: rgba(0, 156, 59, 0.06); border: 1px solid rgba(0, 156, 59, 0.15);">
              <span class="font-mono text-xs font-700 uppercase tracking-wider" style="color: rgba(255, 200, 0, 0.5);">May 2026</span>
              <span class="mt-1 font-display text-lg font-800 text-white">New York City</span>
            </div>
          </div>
        </div>
      </div>

      <div class="absolute bottom-0 left-0 right-0 h-px" style="background: repeating-linear-gradient(90deg, rgba(0,156,59,0.15) 0, rgba(0,156,59,0.15) 8px, transparent 8px, transparent 20px);"></div>
    </section>

    <!-- ═══ About ═══ -->
    <section id="about" class="reveal-section relative py-36">
      <div class="contour-divider"></div>

      <div class="mx-auto max-w-7xl px-6">
        <div class="grid gap-16 lg:grid-cols-12">
          <div class="lg:col-span-4">
            <span class="font-mono text-[10px] font-700 tracking-[0.2em] uppercase" style="color: var(--color-accent);">About the Event</span>
            <h2 class="mt-6 font-display text-4xl font-800 leading-tight tracking-tight sm:text-5xl" style="color: var(--color-midnight);">
              One afternoon.<br />
              <span style="color: var(--color-subtle);">Real conversations.</span>
            </h2>
          </div>

          <div class="space-y-10 lg:col-span-7 lg:col-start-6">
            <p class="text-lg leading-relaxed" style="color: var(--color-muted);">
              Airborne Day is a curated, invite-only full-day event bringing together CEOs, founders, and entrepreneurs in New York City. No panels, no keynotes — just focused conversations between people building and leading companies at the frontier of technology and business.
            </p>
            <p class="text-lg leading-relaxed" style="color: var(--color-muted);">
              We keep the group intimate so every conversation matters. If you're leading a company, scaling a product, or building something ambitious, this is your room.
            </p>

            <!-- Cockpit stat blocks -->
            <div class="mt-14 grid gap-5 sm:grid-cols-3">
              <div class="cockpit-card rounded-lg p-8">
                <span class="font-mono text-[10px] font-700 tracking-[0.2em] uppercase block" style="color: var(--color-accent);">Duration</span>
                <span class="font-mono text-3xl font-700 block mt-2" style="color: var(--color-midnight);">1</span>
                <p class="mt-3 font-mono text-xs uppercase tracking-wider" style="color: var(--color-subtle);">Full day of immersion</p>
              </div>
              <div class="cockpit-card rounded-lg p-8">
                <span class="font-mono text-[10px] font-700 tracking-[0.2em] uppercase block" style="color: var(--color-accent);">Attendees</span>
                <span class="font-mono text-3xl font-700 block mt-2" style="color: var(--color-midnight);">CEOs</span>
                <p class="mt-3 font-mono text-xs uppercase tracking-wider" style="color: var(--color-subtle);">Founders & entrepreneurs</p>
              </div>
              <div class="cockpit-card rounded-lg p-8">
                <span class="font-mono text-[10px] font-700 tracking-[0.2em] uppercase block" style="color: var(--color-accent);">Location</span>
                <span class="font-mono text-3xl font-700 block mt-2" style="color: var(--color-midnight);">NYC</span>
                <p class="mt-3 font-mono text-xs uppercase tracking-wider" style="color: var(--color-subtle);">New York · invite only</p>
              </div>
            </div>

            <!-- Format -->
            <div class="mt-20">
              <h3 class="font-mono text-[10px] font-700 tracking-[0.2em] uppercase" style="color: var(--color-accent);">Format</h3>
              <div class="mt-8">
                <div class="cockpit-card rounded-lg p-8" style="border-left: 2px solid var(--color-accent);">
                  <span class="font-display text-lg font-800" style="color: var(--color-midnight);">
                    May 14th · Full Day · New York City
                  </span>
                  <ul class="mt-6 space-y-4">
                    <li class="flex items-start gap-3 text-base" style="color: var(--color-muted);">
                      <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full animate-blip" style="background: var(--color-accent);"></span>
                      Networking & welcome reception
                    </li>
                    <li class="flex items-start gap-3 text-base" style="color: var(--color-muted);">
                      <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full animate-blip" style="background: var(--color-accent); animation-delay: 0.3s;"></span>
                      Talks from industry leaders and founders
                    </li>
                    <li class="flex items-start gap-3 text-base" style="color: var(--color-muted);">
                      <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full animate-blip" style="background: var(--color-accent); animation-delay: 0.6s;"></span>
                      CEO & entrepreneur roundtables
                    </li>
                    <li class="flex items-start gap-3 text-base" style="color: var(--color-muted);">
                      <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full animate-blip" style="background: var(--color-accent); animation-delay: 0.9s;"></span>
                      Space for direct conversations
                    </li>
                  </ul>
                </div>
              </div>
            </div>

            <!-- Who Attends -->
            <div class="mt-20">
              <h3 class="font-mono text-[10px] font-700 tracking-[0.2em] uppercase" style="color: var(--color-accent);">Who Attends</h3>
              <p class="mt-8 text-base leading-relaxed" style="color: var(--color-muted);">
                We curate for leaders — people actively building products, scaling companies, and making decisions that shape industries.
              </p>
              <ul class="mt-6 space-y-4">
                <li class="flex items-start gap-3 text-base" style="color: var(--color-muted);">
                  <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full animate-blip" style="background: var(--color-accent);"></span>
                  CEOs and founders building venture-backed companies
                </li>
                <li class="flex items-start gap-3 text-base" style="color: var(--color-muted);">
                  <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full animate-blip" style="background: var(--color-accent); animation-delay: 0.2s;"></span>
                  Entrepreneurs scaling products across markets
                </li>
                <li class="flex items-start gap-3 text-base" style="color: var(--color-muted);">
                  <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full animate-blip" style="background: var(--color-accent); animation-delay: 0.4s;"></span>
                  Technical leaders at the frontier of AI and software
                </li>
                <li class="flex items-start gap-3 text-base" style="color: var(--color-muted);">
                  <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full animate-blip" style="background: var(--color-accent); animation-delay: 0.6s;"></span>
                  Investors and operators with deep industry ties
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ Speakers ═══ -->
    <section class="reveal-section relative py-36">
      <div class="contour-divider"></div>

      <div class="mx-auto max-w-7xl px-6">
        <div class="grid gap-16 lg:grid-cols-12">
          <div class="lg:col-span-4">
            <span class="font-mono text-[10px] font-700 tracking-[0.2em] uppercase" style="color: var(--color-accent);">Speaker Profile</span>
            <h2 class="mt-6 font-display text-4xl font-800 leading-tight tracking-tight sm:text-5xl" style="color: var(--color-midnight);">
              Built by<br />
              <span style="color: var(--color-subtle);">practitioners.</span>
            </h2>
          </div>

          <div class="space-y-10 lg:col-span-7 lg:col-start-6">
            <p class="text-lg leading-relaxed" style="color: var(--color-muted);">
              Our speakers are not professional keynote-givers. They are CEOs, founders, and entrepreneurs who are actively building — sharing real lessons from real work. Expect raw, unfiltered takes on strategy, scaling, and the challenges of leading companies at the frontier.
            </p>
            <p class="text-lg leading-relaxed" style="color: var(--color-muted);">
              Past and future speakers come from companies shaping how industries evolve and businesses scale.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ Team ═══ -->
    <section id="team" class="reveal-section relative py-36">
      <div class="contour-divider"></div>

      <div class="mx-auto max-w-7xl px-6">
        <div class="mx-auto max-w-2xl text-center">
          <span class="font-mono text-[10px] font-700 tracking-[0.2em] uppercase" style="color: var(--color-accent);">The Team</span>
          <h2 class="mt-6 font-display text-3xl font-800 leading-tight tracking-tight sm:text-4xl" style="color: var(--color-midnight);">
            The people behind this event.
          </h2>
          <p class="mt-6 text-lg" style="color: var(--color-muted);">
            Connecting CEOs and entrepreneurs for high-signal conversations.
          </p>
        </div>

        <div class="mt-16 grid gap-6 sm:grid-cols-2 max-w-lg mx-auto">
          {team.map((member, i) => (
            <div
